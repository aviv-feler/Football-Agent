# ── סביבה וסודות ──
.env
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# ── נתונים ──
# מתעלמים מכל קבצי הנתונים הגולמיים הכבדים (מ-Kaggle, מאות MB — מעל מגבלת GitHub).
# שומרים רק את מה שהאפליקציה צריכה בזמן ריצה:
#   • players_clean.csv  – הנתונים המעובדים (TF-IDF/clustering נבנים ממנו ב-startup)
#   • fwc26_match_schedule_agent.csv – לוח המונדיאל
data/*
!data/players_clean.csv
!data/fwc26_match_schedule_agent.csv

# embeddings אינם בשימוש בזמן ריצה (הוחלפו ב-TF-IDF)
*.npy
